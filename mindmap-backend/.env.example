# Railway will handle these automatically, but here's what they mean:

# Where the database lives (Railway persistent volume at /app/data)
MINDMAP_DB_PATH=/app/data/mindmap.db

# Server config (Railway handles ports, but these are defaults)
PORT=5002
HOST=0.0.0.0

# Your Letta API key (get from https://console.letta.com)
# This is required for your agent to authenticate with the mindmap API
LETTA_API_KEY=your-letta-api-key-here
